NODE_ENV=development
PORT=5000

# PostgreSQL connection string — point at your local Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/inventory_pos?schema=public"

# Separate database used by the Jest integration suite (optional — tests are skipped if absent)
DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5432/inventory_pos_test?schema=public"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Seed credentials (used by prisma/seed.ts)
SEED_OWNER_EMAIL="owner@demo.local"
SEED_OWNER_PASSWORD="Owner123!"

# CORS — frontend origin
CLIENT_URL="http://localhost:3000"

# Uploads
UPLOAD_DIR="./uploads"
MAX_UPLOAD_BYTES=5242880
